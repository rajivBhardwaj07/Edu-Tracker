# Backend environment variables (set these in Render/Railway dashboard).
# Do NOT commit the real .env file.

NODE_ENV=production

# Render/Railway inject PORT automatically; locally you can use 5000.
PORT=5000

# MongoDB connection string (use MongoDB Atlas for production).
MONGO_URI=your-mongodb-atlas-connection-string

# Auth
JWT_SECRET=your-long-random-secret
JWT_EXPIRE=30d

# URL of your deployed frontend (used for CORS). No trailing slash.
# Example: https://edutrack.vercel.app
FRONTEND_URL=http://localhost:5173
